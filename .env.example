# Copy this file to .env and replace the example paths with local paths.
# .env is intentionally ignored by Git.

NACL_SDK_ROOT=/path/to/pepper_47
EMSDK_ROOT=/path/to/emsdk
SDL2_CONFIG=/path/to/sdl2-config

TIZEN_CLI=tizen
SDB_CLI=sdb
TIZEN_PROFILE=your-signing-profile
TIZEN_TARGET=your-tv-target
TV_ADDRESS=192.0.2.10
